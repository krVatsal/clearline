# ── Database ──────────────────────────────────────────────────────────────────
# Railway: copy the DATABASE_URL from your Railway Postgres plugin
DATABASE_URL="postgresql://clearline:clearline_pass@localhost:5432/clearline_db"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway: copy the REDIS_URL from your Railway Redis plugin
REDIS_URL="redis://localhost:6379"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="supersecretkey-change-in-production-minimum-32-chars"
# Production: set to your Railway public domain, e.g. https://clearline.up.railway.app
NEXTAUTH_URL="http://localhost:3000"

# ── Invite JWT ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
INVITE_JWT_SECRET="invite-secret-change-in-production-minimum-32-chars"

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
# For production use an S3-compatible service (Cloudflare R2, AWS S3, etc.)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="clearline"
MINIO_USE_SSL="false"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── mediasoup ─────────────────────────────────────────────────────────────────
# Railway/PaaS: set to 0.0.0.0 — TURN relay handles cross-network media
# VPS: set to your server's public IP
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40099
MEDIASOUP_ANNOUNCED_IP=0.0.0.0
